NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Feature flags — set to "true" to enable. Off/unset = feature hidden.
# Phone-first Play experience (/play 3-tab shell, /setup Commish page, shot stats):
NEXT_PUBLIC_FEATURE_PLAY_EXPERIENCE=false
# "Tee It Up Now" solo entry flow (/tee-it-up). Requires PLAY_EXPERIENCE=true too:
NEXT_PUBLIC_FEATURE_TEE_IT_UP=false
